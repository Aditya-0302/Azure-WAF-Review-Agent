# ============================================================
# WAF Review Agent — Local Development Environment
# Copy to .env and fill in values. Never commit .env to git.
#
# ONE FILE, ALL COMPONENTS.
# The API server (waf_api) and all four agents read from this
# same file. No per-component variable prefixes are needed.
#
# LLM PROVIDER CHOICE (set LLM_PROVIDER to one of):
#   gemini  — Google Gemini [recommended, free API key, no Azure needed]
#   azure   — Azure OpenAI  [enterprise, requires Azure subscription + deployment]
# ============================================================

# --- Application ---
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=DEBUG
# Auth mode for platform credential provider (Azure SDK — not JWT validation).
# "default_chain" uses DefaultAzureCredential (local dev / CI with env vars).
# "managed_identity" for ACI/AKS. "workload_identity" for AKS OIDC.
AUTH_MODE=default_chain

# API authentication mode (controls JWT validation on incoming HTTP requests).
# "entra"       — validate Azure AD JWTs (required for production).
# "development" — skip JWT validation; synthetic PLATFORM_ADMIN context injected.
#                 NEVER set to "development" when APP_ENV=production (startup fails).
API_AUTH_MODE=development

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# --- PostgreSQL (via PgBouncer in production) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wafagent
DB_USER=wafagent
DB_PASSWORD=changeme_local_only
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10
# Leave DB_READONLY_HOST empty to use the primary pool for reads (single-instance dev).
DB_READONLY_HOST=
DB_READONLY_PORT=5432

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20

# --- Azure Service Bus ---
# Production/staging: set SERVICEBUS_NAMESPACE to your Azure SB namespace.
SERVICEBUS_NAMESPACE=sb-waf-<your-suffix>.servicebus.windows.net
SERVICEBUS_CONNECTION_STRING=

# Local development with Docker Compose emulator:
# SERVICEBUS_EMULATOR_CONNECTION_STRING is injected into all agent containers
# by docker-compose.dev.yml. The compose file already supplies a working default
# (Endpoint=sb://servicebus-emulator) so this is only needed to override it.
# If running agents or tests directly on the host against the emulator, set:
#   SERVICEBUS_CONNECTION_STRING=Endpoint=sb://localhost;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=SAS_KEY_VALUE=;UseDevelopmentEmulator=true;
SERVICEBUS_EMULATOR_CONNECTION_STRING=

# ============================================================
# LLM PROVIDER — choose OPTION A (Gemini) or OPTION B (Azure)
# ============================================================

# --- OPTION A: Google Gemini (recommended default) ---
# Get a free API key at https://aistudio.google.com/app/apikey
# No Azure subscription or deployment required.
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_CHAT_MODEL=gemini-2.5-pro
GEMINI_EMBED_MODEL=text-embedding-004

# --- OPTION B: Azure OpenAI (enterprise path) ---
# Uncomment and fill in all four values, then set LLM_PROVIDER=azure above.
# AZURE_OPENAI_ENDPOINT=https://your-aoai.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT_CHAT=gpt-4o-2024-05-13
# AZURE_OPENAI_API_VERSION=2024-05-01-preview
# AZURE_OPENAI_MAX_TOKENS=4096

# Embedding deployment — reserved for future AI Search knowledge indexing.
# Not required for the core reasoning pipeline.
# AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-3-large-2024-07-01

# --- Azure Key Vault ---
# Required for cross-tenant credential lookup.
# For local dev with a single subscription, the emulator path may skip this.
KEYVAULT_URI=https://kv-waf-<your-suffix>.vault.azure.net/

# --- Azure AI Search ---
# Currently reserved for future knowledge-base integration. Not used at runtime.
SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
SEARCH_INDEX_NAME=waf-knowledge-v1

# --- Azure AD / Entra ID (JWT validation for the API) ---
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=your-client-secret-here
JWT_AUDIENCE=api://waf-agent-api

# --- Azure Storage ---
STORAGE_ACCOUNT_NAME=stwafagent<yoursuffix>
STORAGE_REPORTS_CONTAINER=reports
STORAGE_AUDIT_CONTAINER=audit-exports

# --- Telemetry ---
APPLICATIONINSIGHTS_CONNECTION_STRING=
OTEL_SERVICE_NAME=waf-api
OTEL_EXPORTER_ENABLED=false

# --- Feature flags ---
QUOTA_ENFORCEMENT_ENABLED=true
WEBHOOK_SIGNING_ENABLED=true

# --- Agent tuning (all optional — defaults shown) ---
# Preparation agent
BATCH_SIZE=50
MAX_CONCURRENT_SUBSCRIPTIONS=5
# LLM sampling temperature (applies to both Gemini and Azure OpenAI)
LLM_TEMPERATURE=0.1
